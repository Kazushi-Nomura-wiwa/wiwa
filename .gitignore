# パスとファイル名: .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment files
.env
.env.*

# Logs
*.log

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Test / cache
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build / packaging
build/
dist/
*.egg-info/

# Coverage
.coverage
htmlcov/

# Static files
uploads/img/*
!uploads/img/.gitkeep
uploads/file/*
!uploads/file/.gitkeep
uploads/tmp/*
!uploads/tmp/.gitkeep